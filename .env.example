# StockGuard AI - Environment Variables
# Copy to .env and fill with your values

# Supabase
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-or-secret-key
SUPABASE_ACCESS_TOKEN=your-cli-personal-access-token
SUPABASE_DB_PASSWORD=your-db-password

# App
APP_ENV=development
APP_BASE_URL=http://localhost:3000

# Stripe (Flutter - publishable key only)
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Stripe Price IDs (create in Stripe Dashboard)
STRIPE_STARTER_MONTHLY_PRICE_ID=price_xxx
STRIPE_STARTER_YEARLY_PRICE_ID=price_xxx
STRIPE_GROWTH_MONTHLY_PRICE_ID=price_xxx
STRIPE_GROWTH_YEARLY_PRICE_ID=price_xxx
STRIPE_PRO_MONTHLY_PRICE_ID=price_xxx
STRIPE_PRO_YEARLY_PRICE_ID=price_xxx
