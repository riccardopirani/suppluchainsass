# FabricOS - Environment Variables
# Copy to .env and fill with your values

# Supabase
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Flutter/web: use any one publishable key variable name you prefer:
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-or-secret-key
SUPABASE_ACCESS_TOKEN=your-cli-personal-access-token
SUPABASE_DB_PASSWORD=your-db-password

# App
APP_ENV=development
APP_BASE_URL=http://localhost:3000

# Optional AI key (for future external model integrations)
OPENAI_API_KEY=sk-your-key
